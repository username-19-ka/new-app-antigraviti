auto-install-peers=false
strict-peer-dependencies=false

# Hoist all packages into a flat node_modules structure.
# Required for React Native / Metro bundler to resolve modules correctly.
# Also ensures EAS build servers (which run pnpm from the git root) install
# packages in a way that expo config and Metro can find them.
node-linker=hoisted

# Allow pnpm to install even if the lockfile version is incompatible with
# EAS's internal pnpm version — prevents hard failures on version mismatch.
frozen-lockfile=false
